# Copy to .env and adjust. NEVER commit the real .env file.
DJANGO_SECRET_KEY=replace-with-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=

# PostgreSQL (leave POSTGRES_DB empty to fall back to SQLite for local dev)
POSTGRES_DB=clouderp
POSTGRES_USER=clouderp
POSTGRES_PASSWORD=clouderp_secret
POSTGRES_HOST=db
POSTGRES_PORT=5432
